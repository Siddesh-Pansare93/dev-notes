<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Tutorial Library</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/style.css">
  <script>
    // Apply saved theme/sidebar state before render to prevent flash
    (function() {
      const theme = localStorage.getItem('theme');
      if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      // Only restore sidebar collapsed state on desktop (not mobile — mobile defaults to closed drawer)
      if (window.innerWidth > 768) {
        const sb = localStorage.getItem('sidebar');
        if (sb === 'hidden') document.documentElement.setAttribute('data-sidebar', 'hidden');
      }
    })();
  </script>
</head>
<body>
  <div class="toolbar">
    <!-- Sidebar toggle -->
    <button class="toolbar-btn" id="sidebar-toggle" title="Toggle sidebar (b)" aria-label="Toggle sidebar">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/>
      </svg>
    </button>

    <div class="toolbar-sep"></div>

    <!-- Brand -->
    <a href="/" class="toolbar-brand">
      <div class="toolbar-brand-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
      </div>
      <span class="toolbar-brand-name">Tutorial Library</span>
    </a>

    <!-- Search Button -->
    <button class="search-btn" id="search-toggle" title="Search (/)">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <span class="search-btn-text">Search...</span>
      <span class="search-btn-shortcut">/</span>
    </button>

    <div class="toolbar-spacer"></div>

    <!-- Theme toggle -->
    <button class="toolbar-btn" id="theme-toggle" title="Toggle dark mode" aria-label="Toggle dark mode">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>

  <div class="reading-progress-container">
    <div class="reading-progress-bar" id="reading-progress"></div>
  </div>

  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

  <!-- Search Modal -->
  <div class="search-modal-backdrop" id="search-modal" style="display: none;">
    <div class="search-modal-content">
      <div class="search-input-wrapper">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="search-input" placeholder="Search tutorials..." autocomplete="off">
        <button id="search-close" class="search-close-btn">ESC</button>
      </div>
      <div id="search-results" class="search-results"></div>
    </div>
  </div>

  <aside class="sidebar" id="sidebar">
    <a href="/" class="sidebar-brand">Navigation</a>
    <nav class="sidebar-nav" id="sidebar-nav">
      <%- renderTree(navTree, currentPath) %>
    </nav>
  </aside>

  <main class="content">
    <article class="markdown-body">
      <%- content %>
      
      <% if (locals.prevNode || locals.nextNode) { %>
        <div class="article-navigation">
          <% if (locals.prevNode) { %>
            <a href="/<%= locals.prevNode.path %>" class="nav-prev">
              <span class="nav-label">Previous</span>
              <span class="nav-title"><%= locals.prevNode.label %></span>
            </a>
          <% } else { %>
            <div class="nav-spacer"></div>
          <% } %>
          <% if (locals.nextNode) { %>
            <a href="/<%= locals.nextNode.path %>" class="nav-next">
              <span class="nav-label">Next</span>
              <span class="nav-title"><%= locals.nextNode.label %></span>
            </a>
          <% } else { %>
            <div class="nav-spacer"></div>
          <% } %>
        </div>
      <% } %>
    </article>
    <aside class="page-toc" id="page-toc"></aside>
  </main>

  <script>
    // Theme toggle
    document.getElementById('theme-toggle').addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (isDark) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
      }
    });

    // Sidebar toggle — mobile uses overlay drawer, desktop uses grid collapse
    const isMobile = () => window.matchMedia('(max-width: 768px)').matches;

    function openMobileSidebar() {
      document.documentElement.setAttribute('data-sidebar', 'open');
    }
    function closeMobileSidebar() {
      document.documentElement.removeAttribute('data-sidebar');
    }
    function toggleDesktopSidebar() {
      const isHidden = document.documentElement.getAttribute('data-sidebar') === 'hidden';
      if (isHidden) {
        document.documentElement.removeAttribute('data-sidebar');
        localStorage.setItem('sidebar', 'visible');
      } else {
        document.documentElement.setAttribute('data-sidebar', 'hidden');
        localStorage.setItem('sidebar', 'hidden');
      }
    }

    document.getElementById('sidebar-toggle').addEventListener('click', () => {
      if (isMobile()) {
        const isOpen = document.documentElement.getAttribute('data-sidebar') === 'open';
        isOpen ? closeMobileSidebar() : openMobileSidebar();
      } else {
        toggleDesktopSidebar();
      }
    });

    // Close mobile sidebar when clicking the backdrop
    document.getElementById('sidebar-backdrop').addEventListener('click', closeMobileSidebar);

    // Close mobile sidebar when pressing Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMobile()) closeMobileSidebar();
    });

    // Close mobile sidebar when navigating to a page (clicking a nav link)
    document.getElementById('sidebar-nav').addEventListener('click', (e) => {
      if (isMobile() && e.target.closest('a')) closeMobileSidebar();
    });

    // Swipe gesture: right-edge swipe opens sidebar, left swipe closes it
    (function() {
      let touchStartX = 0;
      let touchStartY = 0;
      const SWIPE_THRESHOLD = 60;
      const EDGE_ZONE = 28; // px from left edge to trigger open

      document.addEventListener('touchstart', e => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      document.addEventListener('touchend', e => {
        if (!isMobile()) return;
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dy) > Math.abs(dx)) return; // vertical scroll, ignore
        const isOpen = document.documentElement.getAttribute('data-sidebar') === 'open';
        if (!isOpen && dx > SWIPE_THRESHOLD && touchStartX < EDGE_ZONE) {
          openMobileSidebar();
        } else if (isOpen && dx < -SWIPE_THRESHOLD) {
          closeMobileSidebar();
        }
      }, { passive: true });
    })();

    // When resizing from mobile to desktop, clean up mobile open state
    window.matchMedia('(max-width: 768px)').addEventListener('change', (e) => {
      if (!e.matches) {
        // Switched to desktop — clear mobile open state, restore desktop preference
        const saved = localStorage.getItem('sidebar');
        document.documentElement.removeAttribute('data-sidebar');
        if (saved === 'hidden') {
          document.documentElement.setAttribute('data-sidebar', 'hidden');
        }
      } else {
        // Switched to mobile — clear desktop hidden state so sidebar is closed by default
        document.documentElement.removeAttribute('data-sidebar');
      }
    });

    // Wrap tables for horizontal scroll on mobile (CSS makes them scroll)
    document.querySelectorAll('.markdown-body table').forEach(table => {
      if (table.parentElement.classList.contains('table-scroll')) return;
      const wrapper = document.createElement('div');
      wrapper.className = 'table-scroll';
      table.parentNode.insertBefore(wrapper, table);
      wrapper.appendChild(table);
    });

    // Enhance code blocks: wrap with header showing language + copy button
    document.querySelectorAll('pre.hljs').forEach(pre => {
      const code = pre.querySelector('code');
      if (!code) return;

      // Detect language from class (hljs adds language-xxx)
      let lang = '';
      for (const cls of code.classList) {
        if (cls.startsWith('language-')) {
          lang = cls.replace('language-', '');
          break;
        }
      }
      // Fallback: check pre classes
      if (!lang) {
        for (const cls of pre.classList) {
          if (cls !== 'hljs') { lang = cls; break; }
        }
      }

      if (lang === 'mermaid') {
        const div = document.createElement('div');
        div.className = 'mermaid';
        div.textContent = code.textContent;
        div.setAttribute('data-original-mermaid', code.textContent);
        pre.parentNode.replaceChild(div, pre);
        return;
      }

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrap';

      const header = document.createElement('div');
      header.className = 'code-block-header';

      const langLabel = document.createElement('span');
      langLabel.className = 'code-block-lang';
      langLabel.textContent = lang || 'code';

      const copyBtn = document.createElement('button');
      copyBtn.className = 'code-copy-btn';
      copyBtn.innerHTML = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy`;

      copyBtn.addEventListener('click', () => {
        const text = code.innerText;
        navigator.clipboard.writeText(text).then(() => {
          copyBtn.classList.add('copied');
          copyBtn.innerHTML = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied`;
          setTimeout(() => {
            copyBtn.classList.remove('copied');
            copyBtn.innerHTML = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy`;
          }, 2000);
        });
      });

      header.appendChild(langLabel);
      header.appendChild(copyBtn);
      wrapper.appendChild(header);

      // Add line numbers gutter
      const lines = code.innerHTML.split('\n');
      if (lines[lines.length - 1] === '') lines.pop(); // remove empty trailing newline
      
      const bodyWrap = document.createElement('div');
      bodyWrap.className = 'code-block-body';
      
      const gutter = document.createElement('div');
      gutter.className = 'code-gutter';
      gutter.innerHTML = lines.map((_, i) => `<span>${i + 1}</span>`).join('');
      
      bodyWrap.appendChild(gutter);
      pre.parentNode.insertBefore(wrapper, pre);
      bodyWrap.appendChild(pre);
      wrapper.appendChild(bodyWrap);
    });

    // 0. Auto-scroll sidebar to active item
    (function() {
      const activeItem = document.querySelector('.sidebar-nav .file.active');
      if (activeItem) {
        activeItem.scrollIntoView({ block: 'center', behavior: 'instant' });
      }
    })();

    // 1. Progress Tracking
    const currentPath = "<%= currentPath %>";
    if (currentPath && currentPath.endsWith('.md')) {
      let completed = JSON.parse(localStorage.getItem('completed') || '[]');
      if (!completed.includes(currentPath)) {
        completed.push(currentPath);
        localStorage.setItem('completed', JSON.stringify(completed));
      }
    }

    const completedFiles = JSON.parse(localStorage.getItem('completed') || '[]');
    
    // Update file checkmarks
    document.querySelectorAll('.sidebar-nav .file').forEach(li => {
      const path = li.getAttribute('data-path');
      if (completedFiles.includes(path)) {
        li.classList.add('completed');
      }
    });

    // Update folder progress
    document.querySelectorAll('.sidebar-nav .folder').forEach(folder => {
      const files = folder.querySelectorAll('.file');
      const completed = folder.querySelectorAll('.file.completed');
      if (files.length > 0) {
        const progressSpan = folder.querySelector('.folder-progress');
        if (progressSpan) {
          progressSpan.textContent = `${completed.length}/${files.length}`;
          if (completed.length === files.length) {
            folder.classList.add('folder-completed');
          }
        }
      }
    });

    // 2. In-page Table of Contents (TOC)
    const headings = document.querySelectorAll('.markdown-body > h2, .markdown-body > h3');
    const tocContainer = document.getElementById('page-toc');
    if (headings.length > 0 && tocContainer && currentPath !== '') {
      const tocHeader = document.createElement('h4');
      tocHeader.textContent = 'On this page';
      tocContainer.appendChild(tocHeader);
      
      const ul = document.createElement('ul');
      const tocLinks = [];
      
      headings.forEach((h, i) => {
        if (!h.id) h.id = 'heading-' + i;
        const li = document.createElement('li');
        li.className = 'toc-' + h.tagName.toLowerCase();
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        li.appendChild(a);
        ul.appendChild(li);
        tocLinks.push({ id: h.id, link: a });
      });
      tocContainer.appendChild(ul);
      
      // Scroll spy for TOC highlighting
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(item => {
              if (item.id === entry.target.id) {
                item.link.classList.add('active');
              } else {
                item.link.classList.remove('active');
              }
            });
          }
        });
      }, { rootMargin: '-10% 0px -80% 0px' });
      
      headings.forEach(h => observer.observe(h));
      
    } else if (tocContainer) {
      tocContainer.style.display = 'none';
    }

    // 3. Reading Progress Bar
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      document.getElementById('reading-progress').style.width = scrolled + '%';
    });

    // 4. Search & Keyboard Navigation
    const searchModal = document.getElementById('search-modal');
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    
    function openSearch() {
      searchModal.style.display = 'flex';
      searchInput.focus();
    }
    
    function closeSearch() {
      searchModal.style.display = 'none';
      searchInput.value = '';
      searchResults.innerHTML = '';
    }

    document.getElementById('search-toggle').addEventListener('click', openSearch);
    document.getElementById('search-close').addEventListener('click', closeSearch);
    searchModal.addEventListener('click', (e) => {
      if (e.target === searchModal) closeSearch();
    });

    let searchTimeout;
    let searchActiveIdx = -1;

    function highlightTerms(text, q) {
      if (!text || !q) return text;
      const terms = q.trim().split(/\s+/).filter(t => t.length >= 2);
      if (!terms.length) return text;
      const regex = new RegExp(`(${terms.map(t => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|')})`, 'gi');
      return text.replace(regex, '<mark>$1</mark>');
    }

    function setActiveResult(idx) {
      const items = searchResults.querySelectorAll('.search-result-item');
      items.forEach((el, i) => el.classList.toggle('keyboard-active', i === idx));
      if (items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
      searchActiveIdx = idx;
    }

    function renderResults(results, q) {
      if (results.length === 0) {
        searchResults.innerHTML = '<div class="search-empty">No results for <strong>' + q + '</strong></div>';
        return;
      }
      const countEl = `<div class="search-count">${results.length} result${results.length !== 1 ? 's' : ''}</div>`;
      const items = results.map((r, i) => `
        <a href="/${r.path}" class="search-result-item" data-idx="${i}">
          <div class="search-result-header">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span class="search-result-title">${highlightTerms(r.title, q)}</span>
            ${r.breadcrumb ? `<span class="search-result-breadcrumb">${r.breadcrumb}</span>` : ''}
          </div>
          ${r.snippet ? `<div class="search-result-snippet">${highlightTerms(r.snippet, q)}</div>` : ''}
        </a>
      `).join('');
      searchResults.innerHTML = countEl + items;
      searchActiveIdx = -1;
    }

    searchInput.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      const q = e.target.value.trim();
      if (!q) { searchResults.innerHTML = ''; return; }

      searchTimeout = setTimeout(() => {
        fetch('/api/search?q=' + encodeURIComponent(q))
          .then(res => res.json())
          .then(results => renderResults(results, q));
      }, 200);
    });

    // Keyboard navigation inside search modal
    searchInput.addEventListener('keydown', (e) => {
      const items = searchResults.querySelectorAll('.search-result-item');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActiveResult(Math.min(searchActiveIdx + 1, items.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActiveResult(Math.max(searchActiveIdx - 1, 0));
      } else if (e.key === 'Enter') {
        if (searchActiveIdx >= 0 && items[searchActiveIdx]) {
          window.location.href = items[searchActiveIdx].href;
        } else if (items.length > 0) {
          window.location.href = items[0].href;
        }
      }
    });

    // Keyboard Shortcuts
    document.addEventListener('keydown', e => {
      // Don't trigger shortcuts if typing in an input
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
        if (e.key === 'Escape') closeSearch();
        return;
      }
      
      if (e.key === '/') {
        e.preventDefault();
        openSearch();
      } else if (e.key === 'b' || e.key === 'B') {
        if (isMobile()) {
          const isOpen = document.documentElement.getAttribute('data-sidebar') === 'open';
          isOpen ? closeMobileSidebar() : openMobileSidebar();
        } else {
          toggleDesktopSidebar();
        }
      } else if (e.key === ']') {
        const next = document.querySelector('.nav-next');
        if (next) window.location.href = next.href;
      } else if (e.key === '[') {
        const prev = document.querySelector('.nav-prev');
        if (prev) window.location.href = prev.href;
      }
    });

  </script>

  <%
  function renderTree(items, currentPath) {
    let html = '<ul>';
    for (const item of items) {
      if (item.type === 'folder') {
        const isOpen = currentPath.startsWith(item.path);
        html += '<li class="folder">';
        html += `<details${isOpen ? ' open' : ''}>`;
        html += `<summary><span class="sidebar-folder-label"><span class="sidebar-folder-text">${item.label}</span><span class="folder-progress"></span></span></summary>`;
        html += renderTree(item.children, currentPath);
        html += '</details>';
        html += '</li>';
      } else {
        const isActive = currentPath === item.path;
        html += `<li class="file${isActive ? ' active' : ''}" data-path="${item.path}">`;
        html += `<a href="/${item.path}"><span>${item.label}</span><span class="file-check">✓</span></a>`;
        html += '</li>';
      }
    }
    html += '</ul>';
    return html;
  }
  %>

  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';

    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    mermaid.initialize({
      startOnLoad: true,
      theme: isDark ? 'dark' : 'base',
      themeVariables: {
        fontFamily: 'DM Sans, sans-serif',
        primaryColor: isDark ? '#181B27' : '#EDE8DF',
        primaryTextColor: isDark ? '#E8E4DE' : '#1C1814',
        primaryBorderColor: isDark ? '#F5A623' : '#C9580C',
        lineColor: isDark ? '#7A7670' : '#A09488',
        secondaryColor: isDark ? '#111420' : '#F5F1E8',
        tertiaryColor: isDark ? '#0D0F16' : '#FDFAF5'
      },
      securityLevel: 'loose'
    });
  </script>

  <script>
  // ── Mermaid diagram zoom lens (Amazon-style magnifier) ─────────────────────
  // Uses SVG viewBox manipulation instead of CSS transforms — no positioning
  // math, guaranteed content, works with any mermaid diagram size.
  (function () {
    const ZOOM = 2.5;
    const R    = 110;   // lens radius → 220 px diameter
    const D    = R * 2;

    function attachZoom(svg) {
      if (svg.hasAttribute('data-mz')) return;
      svg.setAttribute('data-mz', '1');

      const mermaidEl = svg.closest('.mermaid');
      if (!mermaidEl) return;

      // ── wrap ───────────────────────────────────────────────────────────────
      const wrapper = document.createElement('div');
      wrapper.className = 'mz-wrapper';
      mermaidEl.parentNode.insertBefore(wrapper, mermaidEl);
      wrapper.appendChild(mermaidEl);

      const hint = document.createElement('div');
      hint.className = 'mz-hint';
      hint.innerHTML =
        '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">' +
        '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>' +
        '<line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>' +
        '</svg> Hover to zoom';
      wrapper.appendChild(hint);

      // Lens: circular clip window
      const lens = document.createElement('div');
      lens.className = 'mz-lens';
      wrapper.appendChild(lens);

      // ── lazy clone — built once on first hover ─────────────────────────────
      let clone = null;
      function buildClone() {
        if (clone) return;
        clone = svg.cloneNode(true);
        clone.removeAttribute('id');
        // Fill the lens exactly; viewBox controls what region is shown
        clone.style.cssText = 'display:block;width:' + D + 'px;height:' + D + 'px;';
        clone.removeAttribute('width');
        clone.removeAttribute('height');
        lens.appendChild(clone);
      }

      // ── events ─────────────────────────────────────────────────────────────
      let raf;

      wrapper.addEventListener('mouseenter', () => {
        buildClone();
        lens.classList.add('mz-on');
      });
      wrapper.addEventListener('mouseleave', () => {
        lens.classList.remove('mz-on');
        cancelAnimationFrame(raf);
      });

      wrapper.addEventListener('mousemove', (e) => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const wRect = wrapper.getBoundingClientRect();
          const cx = e.clientX - wRect.left;
          const cy = e.clientY - wRect.top;

          // Center lens on cursor
          lens.style.left = (cx - R) + 'px';
          lens.style.top  = (cy - R) + 'px';

          if (!clone) return;

          // Map cursor pixel position → SVG viewBox coordinates
          const sRect = svg.getBoundingClientRect();
          const vb    = svg.viewBox.baseVal;
          // Fall back to pixel size if mermaid didn't set a viewBox
          const vbW = vb.width  || sRect.width;
          const vbH = vb.height || sRect.height;
          const vbX = vb.x || 0;
          const vbY = vb.y || 0;

          // Cursor position in SVG coordinate space
          // (cx is relative to wrapper; SVG may have an offset within wrapper)
          const svgLeft = sRect.left - wRect.left;
          const svgTop  = sRect.top  - wRect.top;
          const svgCx = vbX + ((cx - svgLeft) / sRect.width)  * vbW;
          const svgCy = vbY + ((cy - svgTop)  / sRect.height) * vbH;

          // Region to show: D/ZOOM × D/ZOOM in SVG coords, centred on cursor
          const halfW = (D / ZOOM) / 2;
          const halfH = (D / ZOOM) / 2;

          // Clamp so we don't pan outside the diagram
          const newX = Math.max(vbX, Math.min(svgCx - halfW, vbX + vbW - halfW * 2));
          const newY = Math.max(vbY, Math.min(svgCy - halfH, vbY + vbH - halfH * 2));

          clone.setAttribute('viewBox', newX + ' ' + newY + ' ' + (halfW * 2) + ' ' + (halfH * 2));
        });
      });
    }

    // Watch for mermaid SVGs as they render asynchronously
    const obs = new MutationObserver(() => {
      document.querySelectorAll('.mermaid svg:not([data-mz])').forEach(attachZoom);
    });
    obs.observe(document.body, { childList: true, subtree: true });

    setTimeout(() => {
      document.querySelectorAll('.mermaid svg:not([data-mz])').forEach(attachZoom);
    }, 800);
  })();
  </script>
</body>
</html>
