{
  "nodes": [
    {"id":"title","type":"text","x":-100,"y":-900,"width":700,"height":60,"text":"# Observability Stack: Logs + Metrics + Traces","color":"4"},

    {"id":"app_group","type":"group","x":-100,"y":-800,"width":700,"height":200,"label":"Your Spring Boot Services (each service)","color":"3"},
    {"id":"act","type":"text","x":-80,"y":-770,"width":200,"height":80,"text":"📡 Actuator\n/actuator/health\n/actuator/prometheus"},
    {"id":"mic","type":"text","x":140,"y":-770,"width":200,"height":80,"text":"📊 Micrometer\nCounters, Timers,\nGauges — auto + custom"},
    {"id":"slf","type":"text","x":360,"y":-770,"width":200,"height":80,"text":"📝 SLF4J + Logback\nJSON encoder\nMDC: traceId, userId"},
    {"id":"otel","type":"text","x":580,"y":-770,"width":100,"height":80,"text":"🔍 OTel\nTracing\nSpans"},

    {"id":"export_group","type":"group","x":-100,"y":-550,"width":700,"height":80,"label":"Export / Shipping","color":"5"},
